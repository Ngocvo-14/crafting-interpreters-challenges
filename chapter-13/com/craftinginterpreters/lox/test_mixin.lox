// Mixin providing serialization behavior
class Serializable {
  serialize() {
    return "object:" + this.name;
  }
  describe() {
    return "I am " + this.name;
  }
}

// Mixin providing logging behavior  
class Loggable {
  log() {
    print "LOG: " + this.name;
  }
}

// Animal mixes in both — no superclass needed
class Animal mixin Serializable mixin Loggable {
  init(name) {
    this.name = name;
  }
}

var a = Animal("Cat");
print a.serialize();   // object:Cat
print a.describe();    // I am Cat
a.log();               // LOG: Cat

// Mixin + superclass together
class Pet < Animal mixin Serializable {
  init(name, owner) {
    this.name = name;
    this.owner = owner;
  }
  describe() {
    return this.name + " owned by " + this.owner;
  }
}

var p = Pet("Dog", "Alice");
print p.describe();    // Dog owned by Alice (own method wins)
print p.serialize();   // object:Dog (from mixin)
p.log();               // LOG: Dog (from mixin via Animal's superclass chain)